<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- 内置壁纸标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="内置壁纸"
        android:textColor="@color/white"
        android:alpha="0.6"
        android:textSize="13sp" />

    <!-- 壁纸缩略图网格 (3x2) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- 壁纸 1 -->
        <LinearLayout
            android:id="@+id/wall1Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/wall1"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/shape_wall_item"
                    android:scaleType="centerCrop"
                    android:src="@drawable/wallpaper_1"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <ImageView
                    android:id="@+id/wall1Check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_wall_check"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </FrameLayout>

        </LinearLayout>

        <!-- 壁纸 2 -->
        <LinearLayout
            android:id="@+id/wall2Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/wall2"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/shape_wall_item"
                    android:scaleType="centerCrop"
                    android:src="@drawable/wallpaper_2"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <ImageView
                    android:id="@+id/wall2Check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_wall_check"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

        <!-- 壁纸 3 -->
        <LinearLayout
            android:id="@+id/wall3Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/wall3"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/shape_wall_item"
                    android:scaleType="centerCrop"
                    android:src="@drawable/wallpaper_3"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <ImageView
                    android:id="@+id/wall3Check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_wall_check"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <!-- 壁纸 4 -->
        <LinearLayout
            android:id="@+id/wall4Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/wall4"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/shape_wall_item"
                    android:scaleType="centerCrop"
                    android:src="@drawable/wallpaper_4"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <ImageView
                    android:id="@+id/wall4Check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_wall_check"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

        <!-- 壁纸 5 -->
        <LinearLayout
            android:id="@+id/wall5Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/wall5"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/shape_wall_item"
                    android:scaleType="centerCrop"
                    android:src="@drawable/wallpaper_5"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <ImageView
                    android:id="@+id/wall5Check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_wall_check"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

        <!-- 壁纸 6 (默认) -->
        <LinearLayout
            android:id="@+id/wall6Container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/wall6"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:background="@drawable/shape_wall_item"
                    android:scaleType="centerCrop"
                    android:src="@drawable/wallpaper_6"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <ImageView
                    android:id="@+id/wall6Check"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_wall_check"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginBottom="12dp"
        android:background="@color/white"
        android:alpha="0.15" />

    <!-- 本地图片按钮 -->
    <LinearLayout
        android:id="@+id/localImage"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp"
        android:background="@drawable/selector_item_round"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/photo_prints_24px"
            android:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="从本地相册选择"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_arrow_right"
            android:tint="@color/white"
            android:alpha="0.4" />

    </LinearLayout>

</LinearLayout>
